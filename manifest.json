{
  "manifest_version": 3,
  "name": "Ticket Generator Pro",
  "version": "2.0.0",
  "description": "Convert task descriptions into standardized ticket format using Gemini AI with history, templates, and smart formatting",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardRead",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ticket Generator Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
